# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file -- it's already in .gitignore.

# Required: Gemini API key for the ADK agents.
# Get a free one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: override the model used by all three agents.
ADK_MODEL=gemini-2.5-flash

# Optional: TheSportsDB API key. Defaults to the public "123" test key,
# which is rate-limited but requires no signup. Get a paid personal key at
# https://www.thesportsdb.com/free_api.php if you need higher limits.
THESPORTSDB_API_KEY=123
